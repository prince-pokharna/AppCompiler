{%- set auth_check = 'auth_required' if page.auth_required else '' -%}
export default function {{ page.name | replace(" ", "") }}Page() {
  return (
    <main className="min-h-screen bg-gray-50">
      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <h1 className="text-3xl font-bold text-gray-900 mb-8">{{ page.name }}</h1>
        {% for comp in page.components %}
        <div className="mb-6">
          {/* {{ comp.name }} - {{ comp.type }} */}
          <div className="bg-white p-6 rounded-lg shadow">
            <h2 className="text-xl font-semibold">{{ comp.name }}</h2>
            <p className="text-gray-500">{{ comp.description }}</p>
          </div>
        </div>
        {% endfor %}
      </div>
    </main>
  );
}
