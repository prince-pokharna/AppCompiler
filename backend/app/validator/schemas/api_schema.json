{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "APISchema",
  "type": "object",
  "required": ["endpoints"],
  "properties": {
    "base_path": { "type": "string" },
    "endpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["method", "path"],
        "properties": {
          "method": {
            "type": "string",
            "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
          },
          "path": {
            "type": "string",
            "pattern": "^/api/"
          },
          "group": { "type": "string" },
          "description": { "type": "string" },
          "auth_required": { "type": "boolean" },
          "roles_allowed": {
            "type": "array",
            "items": { "type": "string" }
          },
          "request_body": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "required": { "type": "boolean" },
                "description": { "type": "string" }
              }
            }
          },
          "response_body": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "required": { "type": "boolean" },
                "description": { "type": "string" }
              }
            }
          },
          "query_params": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "required": { "type": "boolean" },
                "description": { "type": "string" }
              }
            }
          }
        }
      },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
