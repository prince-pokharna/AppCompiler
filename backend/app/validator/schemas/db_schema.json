{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DatabaseSchema",
  "type": "object",
  "required": ["tables"],
  "properties": {
    "tables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "columns"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "columns": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "type": {
                  "type": "string",
                  "enum": ["String", "Integer", "Boolean", "DateTime", "Text", "Float", "JSON", "UUID"]
                },
                "primary_key": { "type": "boolean" },
                "nullable": { "type": "boolean" },
                "unique": { "type": "boolean" },
                "default": { "type": ["string", "null"] },
                "description": { "type": "string" }
              }
            },
            "minItems": 1
          },
          "indexes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "columns"],
              "properties": {
                "name": { "type": "string" },
                "columns": {
                  "type": "array",
                  "items": { "type": "string" },
                  "minItems": 1
                },
                "unique": { "type": "boolean" }
              }
            }
          },
          "foreign_keys": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["column", "references_table", "references_column"],
              "properties": {
                "column": { "type": "string" },
                "references_table": { "type": "string" },
                "references_column": { "type": "string" },
                "on_delete": {
                  "type": "string",
                  "enum": ["CASCADE", "SET NULL", "RESTRICT", "NO ACTION"]
                }
              }
            }
          }
        }
      },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
