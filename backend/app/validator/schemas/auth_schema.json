{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AuthSchema",
  "type": "object",
  "required": ["strategy", "roles"],
  "properties": {
    "strategy": {
      "type": "string",
      "enum": ["jwt", "session", "oauth", "api_key"]
    },
    "roles": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "permissions": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["action", "resource"],
          "properties": {
            "action": { "type": "string" },
            "resource": { "type": "string" },
            "conditions": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "jwt_config": {
      "type": "object",
      "properties": {
        "secret_env_var": { "type": "string" },
        "algorithm": { "type": "string", "enum": ["HS256", "RS256", "HS384", "HS512"] },
        "access_token_expiry_minutes": { "type": "integer", "minimum": 1 },
        "refresh_token_expiry_days": { "type": "integer", "minimum": 1 }
      }
    },
    "oauth_providers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "mfa_enabled": { "type": "boolean" }
  },
  "additionalProperties": false
}
