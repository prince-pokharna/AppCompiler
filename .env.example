# OpenAI API key (required)
OPENAI_API_KEY=sk-your-openai-key-here

# API authentication — use the same value in NEXT_PUBLIC_API_KEY for the frontend
API_SECRET_KEY=change-me-to-a-long-random-string
SECRET_KEY=change-me-to-a-long-random-string

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/appcompiler
REDIS_URL=redis://localhost:6379
NEXT_PUBLIC_API_URL=http://localhost:8000
# Proxy mode (recommended): API key stays server-side; leave NEXT_PUBLIC_API_KEY empty
NEXT_PUBLIC_USE_API_PROXY=true
NEXT_PUBLIC_API_KEY=
ENVIRONMENT=development
# Used by Next.js server proxy (same value as API_SECRET_KEY)
INTERNAL_API_URL=http://localhost:8000
